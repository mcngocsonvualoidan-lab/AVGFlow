# ═══════════════════════════════════════
# AVG Flow — .gitignore
# ═══════════════════════════════════════

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment & Secrets
*.local
ext.env
.env
.env.*

# Firebase
.firebase/

# Backups & Manifests
r2_backup_manifest.json
*.manifest.json

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Remote control
.remote-control/

# Temporary files
*.tmp
*.bak
