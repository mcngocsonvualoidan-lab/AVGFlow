rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatar images - public read (no auth needed to display)
    match /avatars/{fileName} {
      allow read;
      allow write: if request.auth != null;
    }
    
    // News banner images - public read (displayed on internal news board)
    match /news_banners/{fileName} {
      allow read;
      allow write: if request.auth != null;
    }
    
    // Existing Chat Uploads (Legacy or General)
    match /chat_uploads/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Internal Chat Files
    match /internal_chat/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Design Ticket Uploads (public access for partners)
    match /design_ticket_uploads/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // AVGFlow_Images — Design order reference images (public for partners)
    match /AVGFlow_Images/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 25 * 1024 * 1024; // Max 25MB
    }

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
