{
    "database": {
        "rules": "database.rules.json"
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "og-orders.png",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=86400"
                    },
                    {
                        "key": "Content-Type",
                        "value": "image/png"
                    }
                ]
            },
            {
                "source": "**/*.@(png|jpg|jpeg|webp)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, max-age=0"
                    }
                ]
            }
        ]
    },
    "extensions": {
        "firestore-send-email": "firebase/firestore-send-email@0.2.4"
    },
    "functions": {
        "source": "functions"
    }
}